{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/css/(.*)",
      "headers": { "Content-Type": "text/css" },
      "dest": "app.py"
    },
    {
      "src": "/static/js/(.*)",
      "headers": { "Content-Type": "application/javascript" },
      "dest": "app.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
